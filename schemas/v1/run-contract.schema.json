{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "v1/run-contract.schema.json",
  "title": "HIVE Run Contract",
  "description": "Schema for the run contract — the initial agreement defining a hive execution run",
  "type": "object",
  "properties": {
    "protocol_version": {
      "type": "string",
      "description": "Protocol version identifier"
    },
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique run identifier (UUID format)"
    },
    "goal": {
      "type": "string",
      "minLength": 1,
      "description": "The primary goal of the run"
    },
    "deliverables": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Expected deliverables from the run"
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Constraints that must be respected during execution"
    },
    "exclusions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Topics, files, or areas explicitly excluded from the run"
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Criteria that define a successful run"
    },
    "approval_requirements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Approval gates that must be satisfied"
    },
    "execution_mode": {
      "$ref": "definitions.schema.json#/$defs/ExecutionMode",
      "description": "Execution mode for this run"
    },
    "maximum_fix_cycles": {
      "type": "integer",
      "minimum": 0,
      "description": "Maximum number of automated fix cycles allowed"
    },
    "status": {
      "$ref": "definitions.schema.json#/$defs/RunStatus",
      "description": "Current status of the run"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the contract was created"
    }
  },
  "required": [
    "protocol_version",
    "run_id",
    "goal",
    "deliverables",
    "constraints",
    "exclusions",
    "success_criteria",
    "approval_requirements",
    "execution_mode",
    "maximum_fix_cycles",
    "status",
    "created_at"
  ],
  "additionalProperties": false
}
